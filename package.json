{
  "name": "jdy_backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "npx nodemon --exec \"node --loader ts-node/esm --openssl-legacy-provider -r dotenv/config\" src/test.ts",
    "test:deepseek-extract": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/extraction/scripts/testDeepseekExtract.ts",
    "test:local-extract": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/extraction/scripts/testLocalExtract.ts",
    "product-config-agent:archive-existing": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/archive/scripts/archiveExistingNormalizedContracts.ts",
    "product-config-agent:refresh-master-data-bindings": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/refreshNormalizationArchivesWithMasterData.ts",
    "product-config-agent:normalize-full": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/runFullNormalizationWithMasterData.ts",
    "product-config-agent:parse-production-detail-excels": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/parseProductionDetailExcels.ts",
    "product-config-agent:report-duplicate-production-detail-documents": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/reportDuplicateProductionDetailDocuments.ts",
    "product-config-agent:apply-duplicate-production-detail-documents": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/reportDuplicateProductionDetailDocuments.ts --apply",
    "product-config-agent:concept-resolver-backfill": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/runConceptResolverBackfill.ts",
    "product-config-agent:concept-resolver-audit": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/runConceptResolverDictionaryAudit.ts",
    "product-config-agent:consolidate-qualifier-terms": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/consolidateQualifierTermTypes.ts",
    "product-config-agent:reextract-cross-concept": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/reextractCrossConceptCandidates.ts",
    "product-config-agent:upgrade-excel-blocks-options": "node --loader ts-node/esm -r dotenv/config src/features/productConfigAgent/scripts/upgradeExcelBlocksOptions.ts",
    "start": "npm install && node build/src/index.js",
    "build": "tsc",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "deploy:mac": "pwsh -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "dev": "npx nodemon --exec \"node --loader ts-node/esm --openssl-legacy-provider -r dotenv/config\" src/dev.ts",
    "test:wechat-config": "node --loader ts-node/esm -r dotenv/config src/scripts/validateWechatConfig.ts",
    "test:wecom-auth": "node --loader ts-node/esm test/wecom_auth.test.ts",
    "test:browser-auth": "node --loader ts-node/esm test/browser_auth.test.ts",
    "typeorm": "typeorm-ts-node-esm"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/node-rsa": "^1.1.4",
    "@wecom/crypto": "^1.0.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.7",
    "body-parser": "^1.20.2",
    "body-parser-xml": "^2.0.5",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mysql": "^2.14.1",
    "node-cron": "^3.0.3",
    "node-rsa": "^1.1.1",
    "openai": "^6.34.0",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.33.5",
    "sm-crypto": "^0.3.13",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/body-parser": "^1.19.5",
    "@types/body-parser-xml": "^2.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@types/sm-crypto": "^0.3.4",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
